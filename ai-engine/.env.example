# Rename this file to .env and fill in your key. Never commit the real .env file.
ANTHROPIC_API_KEY=your_api_key_here

# Model to use for all agents. claude-sonnet-5 is a good default:
# strong reasoning, large context, and cheap enough for a hackathon budget.
CLAUDE_MODEL=claude-sonnet-5

# Comma-separated origins allowed to call this API (your React dev server, deployed frontend, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
